{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "catalogId": "a2ui-starter/core@0.1",
  "version": "0.2.0",
  "title": "A2UI Starter Catalog v0.2",
  "description": "Catalog used by a2ui-starter-web. Extends Google's official basic_catalog with two custom components (OptionsGrid, RichMessageCard). The live zod schemas for the extensions are defined inline at the top of web/index.html; this JSON file is a human-readable reference mirroring that shape.",
  "extends": "https://a2ui.org/specification/v0_9/basic_catalog.json",
  "basic_catalog_components": [
    "Text", "Button", "TextField", "Row", "Column", "List", "Image", "Icon",
    "Video", "AudioPlayer", "Card", "Divider", "CheckBox", "Slider",
    "DateTimeInput", "ChoicePicker", "Tabs", "Modal"
  ],
  "extensions": {
    "OptionsGrid": {
      "description": "A stacked list of tappable options. Each option fires an A2UI event when tapped. Good for agent intake surfaces where the user picks from a small set of routes.",
      "properties": {
        "component": { "const": "OptionsGrid" },
        "id": { "type": "string" },
        "prompt": {
          "description": "Optional heading text shown above the options.",
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/PathBinding" }
          ]
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "action"],
            "properties": {
              "id": { "type": "string" },
              "label": {
                "oneOf": [
                  { "type": "string" },
                  { "$ref": "#/$defs/PathBinding" }
                ]
              },
              "rationale": {
                "description": "Short explanation shown under the label.",
                "oneOf": [
                  { "type": "string" },
                  { "$ref": "#/$defs/PathBinding" }
                ]
              },
              "emoji": { "type": "string" },
              "action": { "$ref": "#/$defs/Action" }
            }
          }
        }
      },
      "required": ["component", "id", "options"]
    },

    "RichMessageCard": {
      "description": "Opinionated recommendation card. Headline + rationale + two actions (confirm / dismiss). Each side ships with a labeled button that fires its own event.",
      "properties": {
        "component": { "const": "RichMessageCard" },
        "id": { "type": "string" },
        "recommendationType": {
          "enum": ["strong", "positive", "lifestyle", "informational", "professional", "alternative"],
          "default": "strong"
        },
        "confidence": { "enum": ["low", "medium", "high"] },
        "headline":  { "oneOf": [ { "type": "string" }, { "$ref": "#/$defs/PathBinding" } ] },
        "rationale": { "oneOf": [ { "type": "string" }, { "$ref": "#/$defs/PathBinding" } ] },
        "confirmAction": { "$ref": "#/$defs/LabeledAction" },
        "dismissAction": { "$ref": "#/$defs/LabeledAction" }
      },
      "required": ["component", "id"]
    }
  },
  "$defs": {
    "PathBinding": {
      "type": "object",
      "properties": { "path": { "type": "string", "description": "JSON Pointer into the surface's data model." } },
      "required": ["path"]
    },
    "Action": {
      "type": "object",
      "properties": {
        "event": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "context": { "type": "object" }
          }
        }
      },
      "required": ["event"]
    },
    "LabeledAction": {
      "type": "object",
      "required": ["label", "event"],
      "properties": {
        "label": { "oneOf": [ { "type": "string" }, { "$ref": "#/$defs/PathBinding" } ] },
        "event": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "oneOf": [ { "type": "string" }, { "$ref": "#/$defs/PathBinding" } ] },
            "context": { "type": "object" }
          }
        }
      }
    }
  }
}
